# URL base da API Laravel
# Produção:   API_BASE_URL=https://seu.dominio.com/api
# Local/dev:  API_BASE_URL=http://127.0.0.1:8000/api
API_BASE_URL=http://127.0.0.1:8000/api

# Hash da estação de trabalho registrada no sistema web
# Obtenha em: Admin > Estações de Trabalho > sua estação
API_WORKSTATION_HASH=WS-XXXXXXXX

# Aceitar certificados self-signed (apenas para desenvolvimento local com Docker)
# Em produção com Let's Encrypt, mantenha false
# ⚠ NUNCA use true em produção
SSL_TRUST_ALL=false
